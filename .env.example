# Database Configuration (PostgreSQL for cloud)
# Get this from Neon or your PostgreSQL provider
DATABASE_URL=postgresql://user:password@localhost:5432/diamond_diary

# Server Configuration
NODE_ENV=development
PORT=5000

# Session Configuration (generate a secure random string for production)
# Optional - will auto-generate if not provided
SESSION_SECRET=your-secure-random-secret-here-change-in-production

# Frontend API Configuration
VITE_API_URL=http://localhost:5000

# Logging
LOG_LEVEL=info

# Production Deployment Example:
# DATABASE_URL=postgresql://user:password@neon.tech/diamond_diary
# NODE_ENV=production
# PORT=5000
# SESSION_SECRET=generate-a-secure-32-char-random-string
# VITE_API_URL=https://your-backend-domain.com

